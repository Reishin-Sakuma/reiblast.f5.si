---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

// 日付でソート（新しい順）
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  }).format(date);
}
---

<Layout title="沖縄でエンジニアしてて思ったこと。 - reiblast1123">
  <main>
    <!-- Hero Section -->
    <section class="blog-hero">
      <div class="minsa-overlay" aria-hidden="true">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="mp-blog" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
              <rect x="0" y="0" width="80" height="5" fill="black"/>
              <polygon points="0,5 8,5 4,15" fill="black"/>
              <polygon points="8,15 16,15 12,5" fill="black"/>
              <polygon points="16,5 24,5 20,15" fill="black"/>
              <polygon points="24,15 32,15 28,5" fill="black"/>
              <polygon points="32,5 40,5 36,15" fill="black"/>
              <polygon points="40,15 48,15 44,5" fill="black"/>
              <polygon points="48,5 56,5 52,15" fill="black"/>
              <polygon points="56,15 64,15 60,5" fill="black"/>
              <polygon points="64,5 72,5 68,15" fill="black"/>
              <polygon points="72,15 80,15 76,5" fill="black"/>
              <rect x="2" y="20" width="8" height="8" fill="black"/>
              <rect x="12" y="20" width="8" height="8" fill="black"/>
              <rect x="2" y="30" width="8" height="8" fill="black"/>
              <rect x="12" y="30" width="8" height="8" fill="black"/>
              <rect x="7" y="40" width="8" height="8" fill="black"/>
              <rect x="42" y="22" width="8" height="8" fill="black"/>
              <rect x="52" y="22" width="8" height="8" fill="black"/>
              <rect x="42" y="32" width="8" height="8" fill="black"/>
              <rect x="52" y="32" width="8" height="8" fill="black"/>
              <polygon points="0,63 8,63 4,73" fill="black"/>
              <polygon points="8,73 16,73 12,63" fill="black"/>
              <polygon points="16,63 24,63 20,73" fill="black"/>
              <polygon points="24,73 32,73 28,63" fill="black"/>
              <polygon points="32,63 40,63 36,73" fill="black"/>
              <polygon points="40,73 48,73 44,63" fill="black"/>
              <polygon points="48,63 56,63 52,73" fill="black"/>
              <polygon points="56,73 64,73 60,63" fill="black"/>
              <polygon points="64,63 72,63 68,73" fill="black"/>
              <polygon points="72,73 80,73 76,63" fill="black"/>
              <rect x="0" y="73" width="80" height="7" fill="black"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#mp-blog)"/>
        </svg>
      </div>
      <div class="container" style="position: relative; z-index: 1;">
        <h1 class="blog-title">沖縄でエンジニアしてて思ったこと</h1>
        <p class="blog-description">
          インフラエンジニアの24歳男子が仕事、趣味、クルマ、社会に対して思ったことを書いてくとこ。<br>
          新入社員が「なるほど、わからん」なところをゆるく解説します。<br>
          ※このブログの内容を実践してあなたに降り掛かったいかなる不都合も不幸も怒号も悪夢も僕は責任を取りません。
        </p>
      </div>
    </section>

    <!-- Blog Posts -->
    <section class="blog-posts">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/">ホーム</a>
          <span class="sep">/</span>
          <span class="current">Blog</span>
        </nav>
        {sortedPosts.length === 0 ? (
          <p class="no-posts">まだ記事がありません。</p>
        ) : (
          <div class="posts-grid">
            {sortedPosts.map((post) => (
              <article class="post-card">
                <a href={`/blog/${post.slug}`} class="post-link">
                  <div class="post-header">
                    <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="post-tags">
                        {post.data.tags.slice(0, 2).map((tag) => (
                          <span class="tag">{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                  <h2 class="post-title">{post.data.title}</h2>
                  <p class="post-description">{post.data.description}</p>
                  <div class="post-footer">
                    <span class="read-more">続きを読む →</span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  <style>
    /* Hero Section */
    .blog-hero {
      padding: 4rem 0 3rem;
      text-align: center;
      background: linear-gradient(135deg, #FFD700 0%, #FFC200 100%);
      color: #111111;
      position: relative;
      overflow: hidden;
    }

    .minsa-overlay {
      position: absolute;
      inset: 0;
      opacity: 0.13;
      pointer-events: none;
      z-index: 0;
    }

    .minsa-overlay svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .blog-title {
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 1rem;
    }

    .blog-description {
      font-size: 1.125rem;
      opacity: 0.9;
      max-width: 600px;
      margin: 0 auto;
    }

    /* Blog Posts */
    .blog-posts {
      padding: 3rem 0 4rem;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .breadcrumb {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-bottom: 2rem;
    }

    .breadcrumb a {
      color: var(--primary);
      text-decoration: none;
    }

    .breadcrumb a:hover {
      text-decoration: underline;
    }

    .breadcrumb .sep {
      margin: 0 0.5rem;
    }

    .breadcrumb .current {
      color: var(--text);
    }

    .no-posts {
      text-align: center;
      color: var(--text-secondary);
      font-size: 1.125rem;
    }

    .posts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .post-card {
      background: var(--surface);
      border-radius: 0.75rem;
      padding: 1.5rem;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .post-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
    }

    .post-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .post-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }

    .post-date {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .post-tags {
      display: flex;
      gap: 0.5rem;
    }

    .tag {
      padding: 0.25rem 0.5rem;
      background: rgba(0, 0, 0, 0.07);
      color: var(--primary);
      border-radius: 0.25rem;
      font-size: 0.75rem;
      font-weight: 500;
    }

    .post-title {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      color: var(--text);
      line-height: 1.3;
    }

    .post-description {
      color: var(--text-secondary);
      margin-bottom: 1rem;
      line-height: 1.6;
    }

    .post-footer {
      display: flex;
      justify-content: flex-end;
    }

    .read-more {
      color: var(--primary);
      font-weight: 600;
      font-size: 0.9375rem;
    }

    .post-link:hover .read-more {
      color: var(--primary-dark);
    }

    @media (max-width: 768px) {
      .blog-title {
        font-size: 2rem;
      }

      .posts-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
