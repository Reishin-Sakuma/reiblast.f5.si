    const STORAGE_KEY = 'liked:' + path;

    function setLiked(count) {
      countEls.forEach(el => { el.textContent = count.toLocaleString('ja-JP'); });
      btns.forEach(btn => {
        btn.classList.add('liked');
        btn.setAttribute('aria-pressed', 'true');
        btn.querySelector('.like-icon').textContent = '♥';
        btn.disabled = true;
      });
    }

    // 既にいいね済みの場合はボタンを無効化
    if (localStorage.getItem(STORAGE_KEY)) {
      btns.forEach(btn => {
        btn.classList.add('liked');
        btn.setAttribute('aria-pressed', 'true');
        btn.querySelector('.like-icon').textContent = '♥';
        btn.disabled = true;
      });
    }

    // 現在のいいね数を取得
    try {
      const res = await fetch('/api/likes?path=' + encodeURIComponent(path));
      if (res.ok) {
        const { count } = await res.json();
        countEls.forEach(el => { el.textContent = count.toLocaleString('ja-JP'); });
      }
    } catch {}

    // ボタンクリック（どちらのボタンでも動作）
    btns.forEach(btn => {
      btn.addEventListener('click', async () => {
        if (btn.disabled) return;
        btns.forEach(b => { b.disabled = true; });
        try {
          const res = await fetch('/api/likes?path=' + encodeURIComponent(path), { method: 'POST' });
          if (res.ok) {
            const { count } = await res.json();
            localStorage.setItem(STORAGE_KEY, '1');
            setLiked(count);
          } else {
            btns.forEach(b => { b.disabled = false; });
          }
        } catch {
          btns.forEach(b => { b.disabled = false; });
        }
      });
    });
  })();
</script>
</Layout>
