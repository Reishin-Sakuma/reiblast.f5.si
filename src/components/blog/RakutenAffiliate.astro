---
interface Props {
  html: string;
}
const { html } = Astro.props;
---
<div class="rakuten-affiliate">
  <Fragment set:html={html} />
</div>

<style>
  .rakuten-affiliate {
    max-width: 100%;
    overflow-x: auto;
  }

  .rakuten-affiliate :global(div[style*="width:624px"]),
  .rakuten-affiliate :global(div[style*="width: 624px"]) {
    width: 100% !important;
  }

  .rakuten-affiliate :global(table) {
    width: 100%;
  }

  @media (max-width: 640px) {
    /* カード内のテーブルを縦積みに */
    .rakuten-affiliate :global(table table tr) {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .rakuten-affiliate :global(table table td) {
      width: 100% !important;
      display: block !important;
      text-align: center;
    }

    /* 商品画像を大きく */
    .rakuten-affiliate :global(table table td img[src*="thumbnail"]),
    .rakuten-affiliate :global(table table td img[src*="hgb"]) {
      width: 200px !important;
      height: auto !important;
    }
  }
</style>
